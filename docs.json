{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Satogate Docs",
  "colors": {
    "primary": "#FFD640",
    "light": "#FFD640",
    "dark": "#FAAF00"
  },
  "favicon": "/favicon.png",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://satogate.io"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "指南",
        "groups": [
          {
            "group": "介绍",
            "icon": "book-open",
            "pages": ["index", "introduction/intro"]
          },
          {
            "group": "快速开始",
            "icon": "rocket",
            "pages": ["start/start"]
          },
          {
            "group": "更多",
            "icon": "circle-info",
            "pages": ["price/price", "contact/contact"]
          }
        ]
      },
      {
        "tab": "API 参考",
        "groups": [
          {
            "group": "认证",
            "icon": "key",
            "pages": ["api/request-signature"]
          },
          {
            "group": "核心接口",
            "icon": "code",
            "pages": [
              "api/01-currency",
              "api/02-wallet",
              "api/03-deposit-order",
              "api/04-project",
              "api/05-transfer",
              "api/07-settlement"
            ]
          },
          {
            "group": "支付页面",
            "icon": "credit-card",
            "pages": [
              "api/payment-page-guide",
              "api/06-payment-page-api"
            ]
          },
          {
            "group": "回调",
            "icon": "arrow-right-arrow-left",
            "pages": ["api/08-callback"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "控制台",
          "href": "https://console.satogate.io",
          "icon": "browser"
        },
        {
          "anchor": "官网",
          "href": "https://satogate.io",
          "icon": "globe"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "联系销售",
        "href": "mailto:sales@satogate.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "控制台",
      "href": "https://console.satogate.io"
    }
  },
  "footer": {
    "socials": {
      "website": "https://satogate.io"
    }
  }
}
